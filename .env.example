# AI Code Security Scanner — environment variables
# Copy this file to .env and fill in your values.
# For Docker: pass these as environment variables in docker-compose.yml or docker run -e.

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the server listens on (default: 3001)
PORT=3001

# CORS allowed origins (comma-separated). If not set, defaults to localhost:5173 and localhost:3001
CORS_ALLOWED_ORIGINS=

# API key required for all server requests.
# If set, every request must include: Authorization: Bearer <key>
# Leave blank to run without authentication (local/trusted environments only).
SERVER_API_KEY=

# ── AI Explanations (optional) ────────────────────────────────────────────────
# Anthropic API key. Required only if you want AI-powered finding explanations
# via the ?aiExplain=true query parameter.
ANTHROPIC_API_KEY=

# ── GitHub integration (optional) ────────────────────────────────────────────
# GitHub personal access token. Required to scan private repositories or to
# avoid the 60 req/hour unauthenticated rate limit on public repo scans.
GITHUB_TOKEN=

# ── Webhook (optional) ────────────────────────────────────────────────────────
# Shared secret used to sign outgoing webhook payloads (HMAC-SHA256).
# Leave blank to disable webhook signature verification.
INTERNAL_API_TOKEN=

# ── Timeouts ──────────────────────────────────────────────────────────────────
# Maximum time in milliseconds for a single file scan before returning 408.
# Default: 30000 (30 seconds)
SCAN_TIMEOUT_MS=

# Maximum time in milliseconds for each GitHub API request when scanning repos.
# Default: 30000 (30 seconds)
GITHUB_REQUEST_TIMEOUT_MS=

# ── Scan cache ────────────────────────────────────────────────────────────────
# Set to "true" to disable the in-memory scan result cache entirely.
# Default: false (cache enabled)
SCAN_CACHE_DISABLED=

# Maximum number of scan result entries held in the in-memory cache.
# Oldest entries are evicted once this limit is reached.
# Default: 5000
SCAN_CACHE_MAX_ENTRIES=

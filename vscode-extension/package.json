{
  "name": "ai-code-security-scanner",
  "displayName": "AI Code Security Scanner",
  "description": "AST-based security scanner for AI-generated code — inline findings in the editor",
  "version": "0.1.0",
  "publisher": "rouco-industries",
  "repository": {
    "type": "git",
    "url": "https://github.com/rouco-industries/ai-code-security-scanner"
  },
  "bugs": {
    "url": "https://github.com/rouco-industries/ai-code-security-scanner/issues"
  },
  "homepage": "https://github.com/rouco-industries/ai-code-security-scanner#readme",
  "license": "MIT",
  "galleryBanner": {
    "color": "#0a0a0f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "security",
    "scanner",
    "ai",
    "vulnerability",
    "linter",
    "typescript",
    "javascript"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:ruby",
    "onLanguage:php",
    "onLanguage:swift",
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiSecScan.scanFile",
        "title": "AI Security: Scan Active File"
      },
      {
        "command": "aiSecScan.scanWorkspace",
        "title": "AI Security: Scan Workspace"
      },
      {
        "command": "aiSecScan.showAIFix",
        "title": "AI Security: Show AI Fix"
      },
      {
        "command": "aiSecScan.scanRepo",
        "title": "AI Security: Scan GitHub Repository"
      }
    ],
    "keybindings": [
      {
        "command": "aiSecScan.scanWorkspace",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "AI Code Security Scanner",
      "properties": {
        "aiSecScan.serverUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "URL of the ai-code-security-scanner backend server"
        },
        "aiSecScan.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token sent as `Authorization: Bearer <key>` on all scan requests. Required when `SERVER_API_KEY` is set on the scanner server. Leave empty for open-access / local dev servers."
        },
        "aiSecScan.autoScanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan the active file on save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}

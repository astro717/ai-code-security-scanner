{
  "name": "ai-code-security-scanner",
  "version": "0.1.0",
  "description": "AST-based security scanner for AI-generated code",
  "main": "dist/cli.js",
  "bin": {
    "ai-sec-scan": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev:cli": "ts-node src/cli.ts",
    "dev:server": "ts-node src/server.ts",
    "dev:web": "cd web && npm run dev",
    "start:server": "node dist/server.js",
    "pretest": "npm run build",
    "test": "npx ts-node --transpile-only tests/scanner.test.ts",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/types": "^7.18.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "minimatch": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
